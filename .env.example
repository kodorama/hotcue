APP_NAME=HotCue
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

VITE_APP_NAME="${APP_NAME}"

# -------------------------------------------------------
# NativePHP / app identity
# -------------------------------------------------------
NATIVEPHP_APP_ID=com.kodorama.hotcue
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_AUTHOR=HotCue
NATIVEPHP_APP_DESCRIPTION="macOS menu bar OBS controller"

# -------------------------------------------------------
# Code signing & notarization (required for native:build --sign)
# Leave blank for unsigned local builds.
# -------------------------------------------------------
NATIVEPHP_APPLE_ID=
NATIVEPHP_APPLE_ID_PASS=
NATIVEPHP_APPLE_TEAM_ID=

# -------------------------------------------------------
# OBS WebSocket defaults (stored in DB; override here for local dev)
# -------------------------------------------------------
# OBS_WS_HOST=127.0.0.1
# OBS_WS_PORT=4455
# OBS_WS_PASSWORD=
